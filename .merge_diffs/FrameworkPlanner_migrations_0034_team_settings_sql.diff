diff --git a/FrameworkPlanner/migrations/0034_team_settings.sql b/FrameworkPlanner/migrations/0034_team_settings.sql
new file mode 100644
index 0000000..27879a9
--- /dev/null
+++ b/FrameworkPlanner/migrations/0034_team_settings.sql
@@ -0,0 +1,28 @@
+CREATE TABLE IF NOT EXISTS team_settings (
+  id INTEGER PRIMARY KEY GENERATED ALWAYS AS IDENTITY,
+  team_id INTEGER NOT NULL,
+  telephony_json JSONB NOT NULL DEFAULT '{}'::jsonb,
+  lead_scoring_json JSONB NOT NULL DEFAULT '{}'::jsonb,
+  assignment_json JSONB NOT NULL DEFAULT '{}'::jsonb,
+  compensation_json JSONB NOT NULL DEFAULT '{}'::jsonb,
+  documents_json JSONB NOT NULL DEFAULT '{}'::jsonb,
+  created_at TIMESTAMP DEFAULT NOW(),
+  updated_at TIMESTAMP DEFAULT NOW(),
+  CONSTRAINT team_settings_team_fk FOREIGN KEY (team_id) REFERENCES teams(id) ON DELETE CASCADE
+);
+
+DO $$
+BEGIN
+  IF NOT EXISTS (
+    SELECT 1
+    FROM pg_constraint
+    WHERE conname = 'team_settings_team_id_uq'
+      AND conrelid = 'team_settings'::regclass
+  ) THEN
+    EXECUTE 'ALTER TABLE team_settings ADD CONSTRAINT team_settings_team_id_uq UNIQUE (team_id)';
+  END IF;
+END
+$$;
+
+CREATE INDEX IF NOT EXISTS team_settings_team_id_idx ON team_settings(team_id);
+
