{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "FrameworkPlanner/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/|assets/|favicon.ico|favicon.png|apple-touch-icon.png|manifest.webmanifest|icon-192.png|icon-512.png|logo.jpg|luxe-logo.png).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
